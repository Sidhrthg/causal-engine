# Data artifacts
data/raw/
# Large BACI raw data inside canonical (11GB+ each)
data/canonical/BACI_HS07/
data/canonical/BACI_HS07_V202601/
# Outputs are gitignored except pre-rendered KG scenario PNGs (used by the
# Scenario Builder page; baked into the Docker image)
outputs/*
!outputs/kg_scenarios/
outputs/kg_scenarios/*
!outputs/kg_scenarios/validation/
!outputs/kg_scenarios/predictive/
!outputs/kg_scenarios/temporal/
outputs/kg_scenarios/validation/*
outputs/kg_scenarios/predictive/*
outputs/kg_scenarios/temporal/*
!outputs/kg_scenarios/validation/*.png
!outputs/kg_scenarios/predictive/*.png
!outputs/kg_scenarios/temporal/*.png
# Track the pre-built KG snapshots PDF so /api/kg/snapshots-export can serve
# it as a static file (server-side generation OOMs the 2GB Fly machine).
!outputs/kg_scenarios/kg_snapshots_appendix.pdf
!outputs/kg_scenarios/kg_yearly_grid_appendix.pdf

# Knowledge Graphs/ folder: track per-commodity PDFs and the README, but
# gitignore the per-year PNGs (~114MB total, regen via
# scripts/build_knowledge_graphs_folder.py).
Knowledge Graphs/*/*.png
!Knowledge Graphs/*/*.pdf
!Knowledge Graphs/README.md

# HippoRAG index (large parquets; not in repo)
data/documents/hipporag_index/

# Scenario suite outputs (large; regenerate locally)
runs/

# Python
__pycache__/
*.pyc
.venv/

# Local env (API keys)
.env
.env.local

# Local Chroma DB
data/chroma_db/

# Editable install metadata
causal_engine.egg-info/

# Raw BACI CSV data (too large for git)
src/minerals/cobalt data/

