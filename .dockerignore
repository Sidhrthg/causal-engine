.venv
__pycache__
*.pyc
*.pyo
.git
.github
.env*
frontend
hipporag_index
runs
*.egg-info
dist
build
.cache
.mypy_cache
.pytest_cache
.idea
.vscode
.DS_Store

# data/: ignore by default, then re-include only what the runtime needs.
data
!data/documents
!data/documents/**
!data/canonical
!data/canonical/*.csv
!data/canonical/*.json

# Ship only the hipporag index variant the production retriever uses
# (gpt-4o-mini + text-embedding-3-large). Drop the empty gpt-4o variant.
data/documents/hipporag_index/gpt-4o_text-embedding-3-large
data/documents/hipporag_index/gpt-4o_text-embedding-3-large/**

# Comtrade / cepii / raw dumps stay out of the image.
data/comtrade
data/comtrade/**
data/canonical/_raw
data/canonical/_raw/**

# outputs/: only bake pre-rendered scenario figures into the image.
outputs
!outputs/kg_scenarios
!outputs/kg_scenarios/validation
!outputs/kg_scenarios/validation/*.png
!outputs/kg_scenarios/predictive
!outputs/kg_scenarios/predictive/*.png
!outputs/kg_scenarios/temporal
!outputs/kg_scenarios/temporal/*.png
!outputs/kg_scenarios/kg_snapshots_appendix.pdf
!outputs/kg_scenarios/kg_yearly_grid_appendix.pdf
# Big per-year grids and caches are dev-only.
outputs/kg_scenarios/yearly_grid
outputs/kg_scenarios/yearly_grid/**
outputs/kg_scenarios/_query_cache.json
outputs/cache
outputs/cache/**

# Knowledge Graphs/: keep only PDFs at top level and in commodity subdirs.
Knowledge Graphs/**
!Knowledge Graphs/
!Knowledge Graphs/README.md
!Knowledge Graphs/*.pdf
!Knowledge Graphs/*/
!Knowledge Graphs/*/*.pdf
# Explicitly exclude archives and raw images.
Knowledge Graphs/Archive.zip
Knowledge Graphs/*.zip
Knowledge Graphs/*/*.png
Knowledge Graphs/*/*.zip

# src/minerals raw data dumps not needed at runtime.
"src/minerals/cobalt data"
src/minerals/*.xlsx
src/minerals/*.xls
src/minerals/*.csv

# Thesis writing artefacts
thesis writing
thesis_combined.md

# scripts/: only one is imported by the API.
scripts
!scripts/run_knowledge_graph.py
!scripts/__init__.py
