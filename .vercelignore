# Ignore Python backend files so Vercel doesn't try to build them.
# Note: do NOT use "*" here — gitignore rules cannot re-include files
# inside an excluded parent directory, so "*" + "!frontend/**" silently
# excludes everything including frontend/.
*.py
pyproject.toml
requirements*.txt
src/
scripts/
data/
hipporag_index/
runs/
configs/
Dockerfile
fly.toml
README.md
